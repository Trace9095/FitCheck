# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# JWT Secret for magic link tokens (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-here

# App URL
NEXT_PUBLIC_APP_URL=https://fitcheckapp.com

# Resend (email)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=noreply@fitcheckapp.com

# Stripe
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Stripe Price IDs
STRIPE_PRICE_PRO_MONTHLY=price_xxxxxxxxxxxx
STRIPE_PRICE_PRO_YEARLY=price_xxxxxxxxxxxx
