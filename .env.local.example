# =============================================================
# EPIC MONOREPO STARTER — Environment Variables
# Copy to apps/web/.env.local and fill in real values.
# NEVER commit .env.local to git.
# =============================================================

# ----- Database (Neon PostgreSQL) --------------------------
# Get from: Neon console → your project → Connection Details
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# ----- Auth (Resend magic links) ---------------------------
# Get RESEND_API_KEY from: resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Generate JWT_SECRET: openssl rand -hex 32
JWT_SECRET=your-64-char-hex-secret-here
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Email address magic links are sent from
AUTH_FROM_EMAIL=noreply@yourdomain.com

# ----- Payments (Stripe — use LIVE keys in production) -----
# Get from: dashboard.stripe.com → Developers → API keys
# IMPORTANT: Use sk_live_ and pk_live_ in production
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxx

# ----- Admin -----------------------------------------------
ADMIN_EMAIL=CEO@epicai.ai
# Generate CRON_SECRET: openssl rand -hex 32
CRON_SECRET=your-64-char-hex-secret-here

# ----- AI (optional — add if project uses AI) --------------
# ANTHROPIC_API_KEY=sk-ant-xxxx

# ----- Vercel (auto-provisioned by vercel env pull) --------
# VERCEL_URL= (auto)
# VERCEL_ENV= (auto)
